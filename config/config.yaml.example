plaid:
  client_id: "your_plaid_client_id"
  secret: "your_plaid_secret"
  environment: "development"  # sandbox | development | production

accounts:
  checking:
    plaid_item: "capital_one"
    account_name: "360 Checking"  # substring match against Plaid account name

  credit_cards:
    # Capital One cards (all under same login/item)
    - name: "Savor"
      plaid_item: "capital_one"
      account_name: "Savor"
      payment_strategy: "statement_balance"  # statement_balance | min_payment | current_balance

    - name: "Venture"
      plaid_item: "capital_one"
      account_name: "Venture"
      payment_strategy: "statement_balance"

    - name: "Venture X"
      plaid_item: "capital_one"
      account_name: "Venture X"
      payment_strategy: "statement_balance"

    # Chase cards - login #1 (United + Marriott)
    - name: "United"
      plaid_item: "chase_1"
      account_name: "United"
      payment_strategy: "statement_balance"

    - name: "Marriott"
      plaid_item: "chase_1"
      account_name: "Marriott"
      payment_strategy: "statement_balance"

    # Chase cards - login #2 (Prime)
    - name: "Amazon Prime"
      plaid_item: "chase_2"
      account_name: "Amazon"
      payment_strategy: "statement_balance"

    # Bank of America
    - name: "Bank of America"
      plaid_item: "bofa"
      account_name: "Premium Rewards"
      payment_strategy: "statement_balance"

    # Citi
    - name: "Citi AAdvantage"
      plaid_item: "citi"
      account_name: "AAdvantage"
      payment_strategy: "statement_balance"

smtp:
  host: "smtp.example.com"
  port: 465
  username: "you@example.com"
  password: "your_app_password"
  from: "you@example.com"
  to: "you@example.com"

thresholds:
  low_balance_warning: 5000

schedule:
  sync:
    days: "mon,wed,sat"
    hour: 10
    minute: 0
  digest:
    days: "sat"
    hour: 10
    minute: 5

digest:
  projection_days_detail: 30    # detail rows in email (transaction days only)
  projection_days_lowpoint: 30  # horizon for low-balance scan
  subject: "Checking Projections - Week of {date}"  # {date} = today's date
  header: "Checking Projections — Week of {date}"   # H2 header in the email body

data_dir: "./data"  # use /app/data when running in Docker
